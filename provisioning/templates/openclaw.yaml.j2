# OpenClaw Configuration Template
# Generated by ClawGeeks Provisioning Engine
# Tenant: {{ tenant.name }} ({{ tenant.id }})

version: 1.0

# Gateway settings
gateway:
  token: "{{ tenant.gateway_token }}"
  host: "0.0.0.0"
  port: 3000

# Model configuration
model:
  default: "{{ tenant.config.model }}"
  thinking: "low"

# Channels (Telegram by default)
channels:
  telegram:
    token: "${TELEGRAM_BOT_TOKEN}"
    allowed_users: []  # Tenant configures via dashboard

{% if tenant.config.shipos_enabled %}
# ShipOS Integration
shipos:
  enabled: true
  max_priorities: 3
  hourly_shipping: true
  spec_before_action: true
{% endif %}

# Multi-agent settings
agents:
  max_agents: {{ tenant.config.max_agents }}
  default_agent: "main"
  
# Security
security:
  sandbox: true
  egress_proxy: true
  audit_log: true

# Workspace
workspace:
  path: "/data/workspace"
  memory_enabled: true

# Tenant metadata
tenant:
  id: "{{ tenant.id }}"
  name: "{{ tenant.name }}"
  tier: "{{ tenant.tier }}"
  created_at: "{{ tenant.created_at.isoformat() }}"
